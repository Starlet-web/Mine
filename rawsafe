    }catch(e){showToast('System Error','error');}
    finally{deleteModal.classList.remove('active');deleteProgress.classList.remove('show');confirmDeleteBtn.disabled=false;}
  });

  const doAuth = async () => {
    const email=emailInput.value.trim().toLowerCase(),pw=passwordInput.value.trim();authError.textContent='';
    if(!email||!pw){authError.textContent='Fill all fields to proceed';return;}
    if(!isLoginMode&&!ALLOWED_EMAILS.includes(email)){authError.textContent='Unauthorized academic email';return;}
    authActionBtn.disabled=true;
    try{if(isLoginMode)await auth.signInWithEmailAndPassword(email,pw);else await auth.createUserWithEmailAndPassword(email,pw);}
    catch(e){authError.textContent={'auth/user-not-found':'Scholar record not found','auth/wrong-password':'Authentication failed'}[e.code]||'Authentication Error';}
    finally{authActionBtn.disabled=false;}
  };

  authActionBtn.addEventListener('click', doAuth);
  passwordInput.addEventListener('keypress', e => { if (e.key === 'Enter') doAuth(); });
  
  toggleAuthBtn.addEventListener('click',()=>{isLoginMode=!isLoginMode;authActionBtn.textContent=isLoginMode?'Access Ecology Portal':'Register Scholar Profile';toggleAuthBtn.textContent=isLoginMode?'New Research Scholar? Register':'Login instead';});
  logoutButton.addEventListener('click',async()=>{if(currentUser)try{await db.collection('presence').doc(currentUser.email).set({online:false,lastSeen:firebase.firestore.FieldValue.serverTimestamp()},{merge:true});}catch(e){}await auth.signOut();});

  notificationBellBtn.addEventListener('click',()=>{unreadCount=0;updateBadge(0);lastReadTimestamp=firebase.firestore.Timestamp.now();switchSection('ai-assistant');});

  async function setOnline(email){try{await db.collection('presence').doc(email).set({online:true,email,lastSeen:firebase.firestore.FieldValue.serverTimestamp()});}catch(e){}}
  function getPartnerEmail(){return currentUser?ALLOWED_EMAILS.find(e=>e!==currentUser.email)||null:null;}
  
  function listenPartnerPresence(){
    const pe = getPartnerEmail();
    if(unsubscribePresence) unsubscribePresence();
    if(!pe){statusDot.className='status-dot offline';partnerDisplayName.textContent='AI Offline';return;}
    
    unsubscribePresence=db.collection('presence').doc(pe).onSnapshot(d=>{
      const on = d.exists && d.data().online === true;
      statusDot.className = on ? 'status-dot' : 'status-dot offline';
      partnerDisplayName.textContent = on ? 'AI Online' : 'AI Offline';
    });
  }

  function setupMessages(){
    if(unsubscribeMessages)unsubscribeMessages();
    unsubscribeMessages=db.collection('messages').orderBy('timestamp','asc').onSnapshot(snap=>{
      [...messagesContainer.children].filter(c=>!c.classList.contains('typing-indicator')&&!c.id.startsWith('temp_')&&!c.classList.contains('persistent-mock')).forEach(c=>c.remove());
      
      let ld='',latestOtherMsg=null;
      snap.forEach(d=>{
        const m=d.data();
        if(m.timestamp?.toDate){const md=m.timestamp.toDate().toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'short'});if(md!==ld){ld=md;const dd=document.createElement('div');dd.className='date-divider';dd.textContent=md;messagesContainer.appendChild(dd);}}
        const div=document.createElement('div');const isOwn=m.senderId===currentUser?.uid;
        div.className=`message-bubble ${isOwn?'own':''}`;
        const label=isOwn?'🧑‍🔬 Doubt Query':'🤖 AI Resolution';
        let contentHtml='';
        if(m.type==='image'&&m.imageUrl){contentHtml=`<img src="${m.imageUrl}" onclick="event.stopPropagation();document.getElementById('fullscreenOverlay').classList.add('active');document.getElementById('fullscreenImage').src='${m.imageUrl}';" loading="lazy">`;}
        else{contentHtml=String(m.text||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
        let metaHtml=`<span>${m.timestamp?.toDate?.().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})||''}</span>`;
        if(isOwn&&m.seen)metaHtml+='<span class="seen-tick">✓✓</span>';else if(isOwn)metaHtml+='<span class="seen-tick single">✓</span>';
        div.innerHTML=`<span class="msg-label">${label}</span>${contentHtml}<div class="message-meta">${metaHtml}</div>`;
        messagesContainer.appendChild(div);
        if(!isOwn&&m.timestamp&&m.timestamp.toMillis()>lastReadTimestamp.toMillis())latestOtherMsg=m;
      });
      if(latestOtherMsg&&currentSection!=='ai-assistant'){newMsgNotification.classList.add('show');unreadCount++;updateBadge(unreadCount);if(Notification.permission==='granted'&&document.hidden)new Notification('Assistant Notification',{body:(latestOtherMsg.text||'📷 Analysis Data attached').substring(0,100)});}
      scrollBottom();
    });
    if(currentUser&&Notification.permission==='default')Notification.requestPermission();
  }

  async function sendMsg(){
    const text=messageInput.value.trim();if(!text||!currentUser)return;messageInput.value='';
    if(typingTimeoutRef)clearTimeout(typingTimeoutRef);
    try{await db.collection('typing').doc(currentUser.email).set({isTyping:false,timestamp:firebase.firestore.FieldValue.serverTimestamp()});}catch(e){}
    try{await db.collection('messages').add({type:'text',text,senderId:currentUser.uid,senderEmail:currentUser.email,timestamp:firebase.firestore.FieldValue.serverTimestamp(),seen:false});}catch(e){showToast('System transmission failed','error');}
  }
  sendButton.addEventListener('click',sendMsg);
  messageInput.addEventListener('keypress',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMsg();}});
  messageInput.addEventListener('input',()=>{
    if(!currentUser)return;try{db.collection('typing').doc(currentUser.email).set({isTyping:true,timestamp:firebase.firestore.FieldValue.serverTimestamp()});}catch(e){}
    if(typingTimeoutRef)clearTimeout(typingTimeoutRef);
    typingTimeoutRef=setTimeout(async()=>{try{await db.collection('typing').doc(currentUser.email).set({isTyping:false,timestamp:firebase.firestore.FieldValue.serverTimestamp()});}catch(e){}},2500);
  });
  
  function listenTyping(){
    const pe = getPartnerEmail();
    if(unsubscribeTyping) unsubscribeTyping();
    if(!pe){typingIndicator.classList.remove('show');return;}
    
    unsubscribeTyping=db.collection('typing').doc(pe).onSnapshot(d=>{
      if(d.exists&&d.data().isTyping){
        typingIndicator.classList.add('show'); scrollBottom();
      }else{
        typingIndicator.classList.remove('show');
      }
    });
  }

  auth.onAuthStateChanged(async user=>{
    if(unsubscribeMessages){unsubscribeMessages();unsubscribeMessages=null;}
    if(unsubscribeTyping){unsubscribeTyping();unsubscribeTyping=null;}
    if(unsubscribePresence){unsubscribePresence();unsubscribePresence=null;}
    if(user){
      if(!ALLOWED_EMAILS.includes(user.email)){await auth.signOut();showAuth();return;}
      currentUser=user;showWorkspace();await setOnline(user.email);
      lastReadTimestamp=firebase.firestore.Timestamp.now();unreadCount=0;updateBadge(0);
      setupMessages();
      listenPartnerPresence();
      listenTyping();
      showToast('System initialization complete','success');
    }else{currentUser=null;showAuth();emailInput.value='';passwordInput.value='';}
  });
  showAuth();
})();
</script>
</body>
</html>
